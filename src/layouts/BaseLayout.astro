---
import "../styles.css";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { alternateLinks, defaultLocale, isLocale, localeHtmlLang, localePath, stripLocale, ui } from "@/lib/i18n";

const {
  title = "buweihao — 精简有效的个人护肤品牌",
  description = "buweihao 是一个面向日常护理的电商产品展示站，覆盖清洁、补水、防晒与抗衰四类核心护肤产品。",
  image,
  noindex = false,
  includeHeader = true,
  includeFooter = true,
  lang,
} = Astro.props;

const pathLocale = Astro.url.pathname.split("/").filter(Boolean)[0];
const currentLocale = isLocale(lang) ? lang : isLocale(pathLocale) ? pathLocale : defaultLocale;
const untranslatedPath = stripLocale(Astro.url.pathname);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const alternates = alternateLinks(Astro.url.pathname).map((item) => ({
  ...item,
  href: new URL(item.href, Astro.site ?? Astro.url.origin).href,
}));
const xDefaultUrl = new URL(localePath(defaultLocale, untranslatedPath), Astro.site ?? Astro.url.origin).href;
const ogImage = image ? new URL(image.src ?? image, Astro.site ?? Astro.url.origin).href : undefined;
const copy = ui[currentLocale];
---

<!doctype html>
<html lang={localeHtmlLang[currentLocale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="buweihao" />
    <meta name="theme-color" content="#f8f7f4" />
    <link rel="canonical" href={canonicalUrl.href} />
    {alternates.map((item) => <link rel="alternate" hreflang={item.hreflang} href={item.href} />)}
    <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="buweihao" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <script is:inline>
      (() => {
        const storageKey = "atelier-ko-cart";

        function readCart() {
          try {
            return JSON.parse(window.localStorage.getItem(storageKey) || "[]");
          } catch {
            return [];
          }
        }

        function writeCart(items) {
          window.localStorage.setItem(storageKey, JSON.stringify(items));
          document.dispatchEvent(new CustomEvent("atelier-cart-change", { detail: items }));
        }

        function count(items = readCart()) {
          return items.reduce((total, item) => total + Number(item.quantity || 0), 0);
        }

        function updateBadges() {
          const total = count();
          document.querySelectorAll("[data-cart-count]").forEach((node) => {
            node.textContent = `(${total})`;
          });
          const labelTemplate = document.body.dataset.cartLabel || "Cart, {count} items";
          document.querySelectorAll("[data-cart-label]").forEach((node) => {
            node.setAttribute("aria-label", labelTemplate.replace("{count}", String(total)));
          });
        }

        window.AtelierCart = {
          read: readCart,
          write: writeCart,
          count,
          add(slug, quantity = 1) {
            const items = readCart();
            const existing = items.find((item) => item.slug === slug);
            if (existing) {
              existing.quantity += quantity;
              writeCart(items);
              return;
            }
            writeCart([...items, { slug, quantity }]);
          },
          remove(slug) {
            writeCart(readCart().filter((item) => item.slug !== slug));
          },
          setQuantity(slug, quantity) {
            if (quantity <= 0) {
              this.remove(slug);
              return;
            }
            writeCart(readCart().map((item) => (item.slug === slug ? { ...item, quantity } : item)));
          },
          updateBadges,
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", updateBadges);
        } else {
          updateBadges();
        }
        window.addEventListener("storage", updateBadges);
        document.addEventListener("atelier-cart-change", updateBadges);
      })();
    </script>
  </head>
  <body class="bg-base text-ink" data-cart-label={copy.cartAria(0).replace("0", "{count}")}>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-full focus:bg-ink focus:px-4 focus:py-2 focus:text-sm focus:text-[var(--color-base)]"
    >
      {copy.skip}
    </a>
    {includeHeader && <SiteHeader currentPath={Astro.url.pathname} lang={currentLocale} />}
    <div>
      <slot />
    </div>
    {includeFooter && <SiteFooter lang={currentLocale} />}
  </body>
</html>
