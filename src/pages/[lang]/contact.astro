---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { isLocale, locales, type Locale } from "@/lib/i18n";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = isLocale(Astro.params.lang) ? Astro.params.lang : "en";
const copy: Record<Locale, any> = {
  en: {
    title: "Contact — buweihao",
    description: "Contact buweihao for product, storefront, or CMS inquiries.",
    eyebrow: "Contact",
    headline: "For partnerships, listings, or CMS work, reach out directly.",
    intro: "This storefront is ready for product display and Sanity-managed content. Use email or the form to continue the product, content, and deployment setup.",
    email: "Email",
    social: "Social",
    domain: "Production domain",
    name: "Name",
    company: "Company",
    phone: "Phone",
    productInterest: "Product interest",
    message: "Message",
    submit: "Send email",
    sending: "Sending...",
    success: "Thanks. Your message has been sent.",
    error: "The message could not be sent. Please email us directly.",
  },
  zh: {
    title: "联系 — buweihao",
    description: "联系 buweihao，邮箱 buweihao@qq.com，社交链接 baidu.com。",
    eyebrow: "Contact",
    headline: "有合作、上架或后台需求，可以直接联系。",
    intro: "当前站点已按电商产品展示结构搭建，并预留 Sanity 后台配置。你可以通过邮箱或社交链接继续完善产品、内容和发布流程。",
    email: "邮箱",
    social: "社交链接",
    domain: "生产域名",
    name: "姓名",
    company: "公司",
    phone: "电话",
    productInterest: "感兴趣的产品",
    message: "留言",
    submit: "发送邮件",
    sending: "发送中...",
    success: "已发送，我们会尽快回复。",
    error: "暂时发送失败，请直接通过邮箱联系我们。",
  },
};
const t = copy[lang];
---

<BaseLayout title={t.title} description={t.description} lang={lang}>
  <main id="main-content">
    <section class="mx-auto max-w-screen-xl px-6 pb-20 pt-20 md:pb-28 md:pt-28">
      <p class="mb-6 flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
        <span class="inline-block h-px w-8 bg-ink/40"></span>
        {t.eyebrow}
      </p>
      <h1 class="max-w-[18ch] text-balance font-serif text-5xl leading-[0.95] md:text-7xl">{t.headline}</h1>
      <p class="mt-8 max-w-[58ch] text-lg leading-relaxed text-faded">{t.intro}</p>
    </section>

    <section class="mx-auto max-w-screen-xl px-6 pb-32">
      <div class="grid gap-8 border-y border-line py-12 md:grid-cols-3">
        <div class="space-y-3">
          <h2 class="text-xs uppercase tracking-[0.25em] text-faded">{t.email}</h2>
          <a href="mailto:buweihao@qq.com" class="font-serif text-3xl transition-colors hover:text-accent">buweihao@qq.com</a>
        </div>
        <div class="space-y-3">
          <h2 class="text-xs uppercase tracking-[0.25em] text-faded">{t.social}</h2>
          <a href="https://baidu.com" class="font-serif text-3xl transition-colors hover:text-accent">baidu.com</a>
        </div>
        <div class="space-y-3">
          <h2 class="text-xs uppercase tracking-[0.25em] text-faded">{t.domain}</h2>
          <a href="https://atelier-ko.weihaobu.cn" class="font-serif text-3xl transition-colors hover:text-accent">atelier-ko.weihaobu.cn</a>
        </div>
      </div>

      <form class="mt-16 grid gap-5 md:grid-cols-2" method="post" action="mailto:buweihao@qq.com" data-contact-form>
        <input type="hidden" name="locale" value={lang} />
        <input type="hidden" name="sourceUrl" value={Astro.url.href} />
        <label class="hidden" aria-hidden="true">
          Website
          <input name="website" tabindex="-1" autocomplete="off" />
        </label>
        <label class="block">
          <span class="text-[11px] uppercase tracking-widest text-faded">{t.name}</span>
          <input name="name" required class="mt-2 w-full border-b border-line bg-transparent py-3 text-sm transition-colors focus:border-ink focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-[11px] uppercase tracking-widest text-faded">{t.email}</span>
          <input name="email" type="email" required class="mt-2 w-full border-b border-line bg-transparent py-3 text-sm transition-colors focus:border-ink focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-[11px] uppercase tracking-widest text-faded">{t.company}</span>
          <input name="company" class="mt-2 w-full border-b border-line bg-transparent py-3 text-sm transition-colors focus:border-ink focus:outline-none" />
        </label>
        <label class="block">
          <span class="text-[11px] uppercase tracking-widest text-faded">{t.phone}</span>
          <input name="phone" class="mt-2 w-full border-b border-line bg-transparent py-3 text-sm transition-colors focus:border-ink focus:outline-none" />
        </label>
        <label class="block md:col-span-2">
          <span class="text-[11px] uppercase tracking-widest text-faded">{t.productInterest}</span>
          <input name="productInterest" class="mt-2 w-full border-b border-line bg-transparent py-3 text-sm transition-colors focus:border-ink focus:outline-none" />
        </label>
        <label class="block md:col-span-2">
          <span class="text-[11px] uppercase tracking-widest text-faded">{t.message}</span>
          <textarea name="message" required rows="5" class="mt-2 w-full resize-y border-b border-line bg-transparent py-3 text-sm transition-colors focus:border-ink focus:outline-none"></textarea>
        </label>
        <div class="space-y-4 md:col-span-2">
          <button type="submit" class="inline-flex items-center justify-center gap-3 rounded-full bg-ink px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent disabled:cursor-wait disabled:opacity-60" data-contact-submit>
            {t.submit}
          </button>
          <p class="hidden max-w-[58ch] text-sm leading-relaxed" data-contact-status aria-live="polite"></p>
        </div>
      </form>
    </section>

    <script is:inline define:vars={{ labels: { submit: t.submit, sending: t.sending, success: t.success, error: t.error } }}>
      const form = document.querySelector("[data-contact-form]");
      const button = document.querySelector("[data-contact-submit]");
      const status = document.querySelector("[data-contact-status]");

      if (form && button && status) {
        form.addEventListener("submit", async (event) => {
          event.preventDefault();
          const formData = new FormData(form);
          const payload = Object.fromEntries(formData.entries());

          button.disabled = true;
          button.textContent = labels.sending;
          status.className = "max-w-[58ch] text-sm leading-relaxed text-faded";
          status.textContent = labels.sending;

          try {
            const response = await fetch("/api/contact", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
            });
            const result = await response.json().catch(() => ({}));

            if (!response.ok || !result.ok) {
              throw new Error(result.error || "Unable to send");
            }

            form.reset();
            status.className = "max-w-[58ch] text-sm leading-relaxed text-ink";
            status.textContent = labels.success;
          } catch {
            status.className = "max-w-[58ch] text-sm leading-relaxed text-accent";
            status.textContent = labels.error;
          } finally {
            button.disabled = false;
            button.textContent = labels.submit;
          }
        });
      }
    </script>
  </main>
</BaseLayout>
