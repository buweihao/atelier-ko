---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import heroImg from "@/assets/buweihao-hero.jpg";
import { isLocale, locales, type Locale } from "@/lib/i18n";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = isLocale(Astro.params.lang) ? Astro.params.lang : "en";
const copy: Record<Locale, any> = {
  en: {
    title: "About — buweihao",
    description: "Learn about buweihao's skincare principles and product system.",
    eyebrow: "About buweihao",
    headline: "Less complexity, more daily care people actually use.",
    intro: "buweihao is a skincare showcase organized around cleansing, hydration, sunscreen, and renewal so shoppers can understand each product's place in a routine.",
    principle: "Brand principle",
    principleTitle: "A clear product line matters more than stacking concepts.",
    p1: "We organize the line into four easy-to-understand routines: cleansing as the base, hydration for comfort, sunscreen for daytime protection, and renewal for night care.",
    p2: "The site stays static and fast while keeping room for Sanity content management, multilingual fields, and future commerce or inquiry workflows.",
    organize: "How we organize products",
    blocks: [
      ["01", "Cleanse", "A gentle first step that cleans without stripping."],
      ["02", "Hydrate", "Light hydration helps the rest of the routine layer smoothly."],
      ["03", "Protect", "Daily sunscreen should feel fresh enough to use every day."],
      ["04", "Renew", "Night care focuses on comfort, barrier support, and a smoother look."],
    ],
    stats: [["4", "Core categories"], ["4", "Showcase products"], ["Sanity", "CMS ready"], ["Static", "Fast storefront"]],
  },
  zh: {
    title: "关于 — buweihao",
    description: "了解 buweihao 的护肤理念、产品结构和清洁、补水、防晒、抗衰四类产品方向。",
    eyebrow: "About buweihao",
    headline: "不追复杂，只做日常真正会用的护理。",
    intro: "buweihao 是一个个人护肤品牌展示站，围绕清洁、补水、防晒、抗衰四个高频需求组织产品，让用户快速理解每件产品适合放在哪一步。",
    principle: "Brand principle",
    principleTitle: "把产品线做得清晰，比堆叠概念更重要。",
    p1: "我们把产品拆成四个用户容易理解的护理场景：清洁负责打底，补水提升舒适度，防晒承担日间防护，抗衰放在夜间修护节奏里。",
    p2: "这个站点当前以静态展示为主，保留购物车预览和 Sanity 后台扩展空间，适合从品牌展示逐步升级为真实电商。",
    organize: "How we organize products",
    blocks: [
      ["01", "清洁", "温和清洁是稳定护肤流程的第一步，重点是洗净但不过度。"],
      ["02", "补水", "轻盈补水帮助后续产品铺展，也让肌肤状态更稳定。"],
      ["03", "防晒", "日间防护应当清爽、好涂、愿意每天坚持。"],
      ["04", "抗衰", "夜间修护关注屏障、干纹观感和长期弹润感。"],
    ],
    stats: [["4", "核心分类"], ["4", "展示产品"], ["Sanity", "后台预留"], ["Static", "快速前台"]],
  },
};
const t = copy[lang];
---

<BaseLayout title={t.title} description={t.description} image={heroImg} lang={lang}>
  <main id="main-content">
    <section class="mx-auto max-w-screen-xl px-6 pb-16 pt-20 md:pb-24 md:pt-28">
      <p class="mb-6 flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
        <span class="inline-block h-px w-8 bg-ink/40"></span>
        {t.eyebrow}
      </p>
      <h1 class="max-w-[18ch] text-balance font-serif text-5xl leading-[0.95] md:text-7xl">{t.headline}</h1>
      <p class="mt-8 max-w-[58ch] text-lg leading-relaxed text-faded">{t.intro}</p>
    </section>

    <section class="relative w-full">
      <Image src={heroImg} alt="buweihao skincare products" width={1920} height={1080} format="webp" loading="eager" class="h-[50vh] w-full object-cover object-right md:h-[70vh]" />
    </section>

    <section class="mx-auto mt-24 grid max-w-screen-xl gap-10 px-6 md:mt-32 md:grid-cols-12 md:gap-16">
      <div class="md:col-span-5">
        <p class="mb-6 text-[11px] uppercase tracking-[0.3em] text-faded">{t.principle}</p>
        <h2 class="text-balance font-serif text-3xl leading-[1.02] md:text-5xl">{t.principleTitle}</h2>
      </div>
      <div class="space-y-6 leading-relaxed text-faded md:col-span-6 md:col-start-7">
        <p>{t.p1}</p>
        <p>{t.p2}</p>
      </div>
    </section>

    <section class="mx-auto mt-24 max-w-screen-xl border-t border-line px-6 pt-12 md:mt-32">
      <p class="mb-12 text-[11px] uppercase tracking-[0.3em] text-faded">{t.organize}</p>
      <div class="grid gap-x-8 gap-y-12 md:grid-cols-4">
        {t.blocks.map((block) => (
          <div class="space-y-3">
            <p class="text-[10px] uppercase tracking-[0.3em] text-faded tabular-nums">{block[0]}</p>
            <h3 class="font-serif text-2xl">{block[1]}</h3>
            <p class="text-sm leading-relaxed text-faded">{block[2]}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mx-auto mb-32 mt-24 max-w-screen-xl border-y border-line px-6 py-12 md:mt-32">
      <div class="grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-4">
        {t.stats.map((stat) => (
          <div class="space-y-2">
            <p class="font-serif text-4xl tabular-nums md:text-5xl">{stat[0]}</p>
            <p class="text-[10px] uppercase tracking-[0.3em] text-faded">{stat[1]}</p>
          </div>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
