---
import { Image } from "astro:assets";
import ProductCard from "@/components/ProductCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import heroImg from "@/assets/buweihao-hero.jpg";
import { getProducts, localizeCategory } from "@/data/products.js";
import { isLocale, locales, localePath, type Locale } from "@/lib/i18n";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const lang = isLocale(Astro.params.lang) ? Astro.params.lang : "en";
const products = await getProducts(lang);

const copy: Record<Locale, any> = {
  en: {
    title: "buweihao — Cleansing, hydration, sunscreen, and renewal skincare",
    description: "buweihao is a focused skincare showcase for cleansing, hydration, sunscreen, and renewal essentials.",
    heroAlt: "buweihao minimal skincare product set",
    eyebrow: "Clean care for everyday skin",
    headline: "Make daily skincare feel clear.",
    intro: "From cleansing and hydration to sunscreen and renewal, buweihao organizes daily skincare into lightweight, useful, easy-to-repeat steps.",
    cta: "View products",
    secondary: "Contact us",
    system: "Product system",
    systemTitle: "Four steps for everyday skin.",
    allProducts: "All products",
    featured: "Featured products",
    featuredTitle: "Core products ready for a clean storefront.",
    sanity: "Sanity ready",
    sanityTitle: "Content can live in Sanity while the storefront stays static and fast.",
    sanityText: "Products currently fall back to Astro content collections, with Sanity Studio and a product schema ready for managed content, images, and multilingual fields.",
    inquiry: "Start an inquiry",
    categories: [
      { name: "清洁", heading: "Cleanse", copy: "A gentle first step that removes oil, sunscreen, and daily buildup without a tight finish." },
      { name: "补水", heading: "Hydrate", copy: "Light water-based formulas to prepare dry or seasonal skin for the next step." },
      { name: "防晒", heading: "Protect", copy: "Fresh daily UV protection for commuting, travel, and consistent everyday use." },
      { name: "抗衰", heading: "Renew", copy: "Night care focused on comfort, barrier support, and the look of fine lines." },
    ],
  },
  zh: {
    title: "buweihao — 清洁、补水、防晒、抗衰护肤产品",
    description: "buweihao 是一个个人护肤电商产品展示站，提供清洁、补水、防晒与抗衰四类日常护肤产品。",
    heroAlt: "buweihao 极简护肤产品组合",
    eyebrow: "Clean care for everyday skin",
    headline: "把日常护肤做清楚。",
    intro: "从清洁、补水、防晒到抗衰，围绕每天都会用到的护肤步骤，提供轻盈、有效、好坚持的产品组合。",
    cta: "查看产品",
    secondary: "联系我们",
    system: "Product system",
    systemTitle: "四个步骤，覆盖日常护理。",
    allProducts: "全部产品",
    featured: "Featured products",
    featuredTitle: "适合上架展示的核心产品。",
    sanity: "Sanity ready",
    sanityTitle: "内容可迁移到 Sanity，前台保持静态快速。",
    sanityText: "当前产品以 Astro 内容集合驱动，已补充 Sanity Studio 配置和产品 schema，后续可以接入 Sanity dataset 管理产品、分类与图片。",
    inquiry: "合作咨询",
    categories: [
      { name: "清洁", heading: "清洁护理", copy: "温和带走油脂、防晒与日常脏污，保留洗后舒适感。" },
      { name: "补水", heading: "补水护理", copy: "用轻盈水感配方，为干燥和换季状态打好底。" },
      { name: "防晒", heading: "防晒护理", copy: "清爽成膜，适合通勤、出行和每天都要做的防护。" },
      { name: "抗衰", heading: "抗衰护理", copy: "围绕屏障、干纹和弹润观感，建立夜间修护节奏。" },
    ],
  },
};

const t = copy[lang];
---

<BaseLayout title={t.title} description={t.description} image={heroImg} lang={lang}>
  <main id="main-content">
    <section class="relative overflow-hidden bg-base">
      <div class="md:hidden">
        <div class="aspect-[4/3] w-full">
          <Image src={heroImg} alt={t.heroAlt} width={1600} height={1100} format="webp" loading="eager" decoding="sync" class="h-full w-full object-cover object-right" />
        </div>
        <div class="space-y-6 px-6 py-12">
          <p class="flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
            <span class="inline-block h-px w-8 bg-ink/40"></span>
            {t.eyebrow}
          </p>
          <h1 class="text-balance font-serif text-4xl leading-[0.95]">
            buweihao
            <br />
            <span class="italic text-accent">{t.headline}</span>
          </h1>
          <p class="max-w-[48ch] text-pretty leading-relaxed text-faded">{t.intro}</p>
          <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center">
            <a href={localePath(lang, "/products")} class="group inline-flex items-center gap-3 rounded-full bg-ink px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent">
              {t.cta}
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
            </a>
            <a href={localePath(lang, "/about")} class="text-[11px] uppercase tracking-[0.2em] text-faded transition-colors hover:text-ink">
              {lang === "zh" ? "了解品牌" : "About the brand"} →
            </a>
          </div>
        </div>
      </div>

      <div class="relative hidden h-[88vh] max-h-[920px] min-h-[640px] w-full md:block">
        <Image src={heroImg} alt={t.heroAlt} width={2048} height={1200} format="webp" loading="eager" decoding="sync" class="absolute inset-0 h-full w-full object-cover object-right" />
        <div aria-hidden="true" class="absolute inset-0" style="background: linear-gradient(90deg, var(--color-base) 0%, var(--color-base) 30%, color-mix(in oklab, var(--color-base) 62%, transparent) 48%, transparent 78%)"></div>
        <div class="relative mx-auto flex h-full max-w-screen-xl items-center px-6">
          <div class="max-w-[500px] space-y-8">
            <p class="flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
              <span class="inline-block h-px w-8 bg-ink/40"></span>
              {t.eyebrow}
            </p>
            <h1 class="text-balance font-serif text-5xl leading-[0.95] lg:text-7xl">
              buweihao
              <br />
              <span class="italic text-accent">{t.headline}</span>
            </h1>
            <p class="max-w-[48ch] text-pretty leading-relaxed text-faded md:text-lg">{t.intro}</p>
            <div class="flex items-center gap-6 pt-2">
              <a href={localePath(lang, "/products")} class="group inline-flex items-center gap-3 rounded-full bg-ink px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent">
                {t.cta}
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
              </a>
              <a href={localePath(lang, "/contact")} class="text-[11px] uppercase tracking-[0.2em] text-faded transition-colors hover:text-ink">
                {t.secondary} →
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-screen-xl px-6 pt-24 md:pt-32">
      <div class="mb-12 flex items-end justify-between gap-6 border-t border-line pt-10">
        <div>
          <p class="mb-4 text-[11px] uppercase tracking-[0.3em] text-faded">{t.system}</p>
          <h2 class="max-w-[18ch] text-balance font-serif text-3xl md:text-5xl">
            {t.systemTitle}
          </h2>
        </div>
        <a href={localePath(lang, "/products")} class="hidden items-center gap-2 whitespace-nowrap text-[11px] uppercase tracking-[0.2em] text-faded transition-colors hover:text-ink md:inline-flex">
          {t.allProducts}
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="grid gap-x-8 gap-y-10 md:grid-cols-4">
        {
          t.categories.map((item) => (
            <a href={`${localePath(lang, "/products")}?category=${encodeURIComponent(localizeCategory(item.name, lang))}`} class="space-y-3 border-t border-line pt-5 transition-colors hover:text-accent">
              <p class="text-[10px] uppercase tracking-[0.3em] text-faded">{localizeCategory(item.name, lang)}</p>
              <h3 class="font-serif text-2xl">{item.heading}</h3>
              <p class="text-sm leading-relaxed text-faded">{item.copy}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="mx-auto mt-32 max-w-screen-xl px-6 md:mt-40">
      <div class="mb-12 flex items-end justify-between gap-6 border-t border-line pt-10">
        <div>
          <p class="mb-4 text-[11px] uppercase tracking-[0.3em] text-faded">{t.featured}</p>
          <h2 class="max-w-[20ch] text-balance font-serif text-3xl md:text-5xl">{t.featuredTitle}</h2>
        </div>
      </div>
      <div class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-4">
        {products.map((product, index) => <ProductCard product={product} eager={index < 2} lang={lang} />)}
      </div>
    </section>

    <section class="mx-auto my-32 max-w-screen-xl px-6 md:my-40">
      <div class="grid items-end gap-10 border-y border-line py-12 md:grid-cols-12">
        <div class="md:col-span-7">
          <p class="mb-5 text-[11px] uppercase tracking-[0.3em] text-faded">{t.sanity}</p>
          <h2 class="max-w-[18ch] text-balance font-serif text-3xl md:text-5xl">{t.sanityTitle}</h2>
        </div>
        <div class="space-y-5 text-sm leading-relaxed text-faded md:col-span-5">
          <p>{t.sanityText}</p>
          <a href={localePath(lang, "/contact")} class="inline-flex text-[11px] uppercase tracking-[0.2em] text-ink transition-colors hover:text-accent">
            {t.inquiry} →
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
