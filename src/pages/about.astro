---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import heroImg from "@/assets/buweihao-hero.jpg";
---

<BaseLayout
  title="关于 — buweihao"
  description="了解 buweihao 的护肤理念、产品结构和清洁、补水、防晒、抗衰四类产品方向。"
  image={heroImg}
>
  <main id="main-content">
    <section class="mx-auto max-w-screen-xl px-6 pb-16 pt-20 md:pb-24 md:pt-28">
      <p class="mb-6 flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
        <span class="inline-block h-px w-8 bg-ink/40"></span>
        About buweihao
      </p>
      <h1 class="max-w-[18ch] text-balance font-serif text-5xl leading-[0.95] md:text-7xl">
        不追复杂，<span class="italic text-accent">只做日常真正会用的护理。</span>
      </h1>
      <p class="mt-8 max-w-[58ch] text-lg leading-relaxed text-faded">
        buweihao 是一个个人护肤品牌展示站，围绕清洁、补水、防晒、抗衰四个高频需求组织产品，让用户快速理解每件产品适合放在哪一步。
      </p>
    </section>

    <section class="relative w-full">
      <Image
        src={heroImg}
        alt="buweihao 护肤产品与清透水面场景"
        width={1920}
        height={1080}
        format="webp"
        loading="eager"
        class="h-[50vh] w-full object-cover object-right md:h-[70vh]"
      />
    </section>

    <section class="mx-auto mt-24 grid max-w-screen-xl gap-10 px-6 md:mt-32 md:grid-cols-12 md:gap-16">
      <div class="md:col-span-5">
        <p class="mb-6 text-[11px] uppercase tracking-[0.3em] text-faded">Brand principle</p>
        <h2 class="text-balance font-serif text-3xl leading-[1.02] md:text-5xl">把产品线做得清晰，比堆叠概念更重要。</h2>
      </div>
      <div class="space-y-6 leading-relaxed text-faded md:col-span-6 md:col-start-7">
        <p>
          我们把产品拆成四个用户容易理解的护理场景：清洁负责打底，补水提升舒适度，防晒承担日间防护，抗衰放在夜间修护节奏里。
        </p>
        <p>
          这个站点当前以静态展示为主，保留购物车预览和 Sanity 后台扩展空间，适合从品牌展示逐步升级为真实电商。
        </p>
      </div>
    </section>

    <section class="mx-auto mt-24 max-w-screen-xl border-t border-line px-6 pt-12 md:mt-32">
      <p class="mb-12 text-[11px] uppercase tracking-[0.3em] text-faded">How we organize products</p>
      <div class="grid gap-x-8 gap-y-12 md:grid-cols-4">
        {
          [
            { n: "01", h: "清洁", p: "温和清洁是稳定护肤流程的第一步，重点是洗净但不过度。" },
            { n: "02", h: "补水", p: "轻盈补水帮助后续产品铺展，也让肌肤状态更稳定。" },
            { n: "03", h: "防晒", p: "日间防护应当清爽、好涂、愿意每天坚持。" },
            { n: "04", h: "抗衰", p: "夜间修护关注屏障、干纹观感和长期弹润感。" },
          ].map((block) => (
            <div class="space-y-3">
              <p class="text-[10px] uppercase tracking-[0.3em] text-faded tabular-nums">{block.n}</p>
              <h3 class="font-serif text-2xl">{block.h}</h3>
              <p class="text-sm leading-relaxed text-faded">{block.p}</p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mx-auto mb-32 mt-24 max-w-screen-xl border-y border-line px-6 py-12 md:mt-32">
      <div class="grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-4">
        {
          [
            { n: "4", l: "核心分类" },
            { n: "4", l: "展示产品" },
            { n: "Sanity", l: "后台预留" },
            { n: "Static", l: "快速前台" },
          ].map((stat) => (
            <div class="space-y-2">
              <p class="font-serif text-4xl tabular-nums md:text-5xl">{stat.n}</p>
              <p class="text-[10px] uppercase tracking-[0.3em] text-faded">{stat.l}</p>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
