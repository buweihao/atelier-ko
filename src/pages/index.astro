---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="buweihao"
  description="Choose your preferred language for buweihao."
  includeHeader={false}
  includeFooter={false}
  noindex={true}
>
  <main id="main-content" class="grid min-h-dvh place-items-center px-6 text-center">
    <div class="space-y-6">
      <p class="font-serif text-4xl italic">buweihao</p>
      <p class="text-sm text-faded">Choosing your language...</p>
      <div class="flex justify-center gap-3">
        <a href="/en" class="rounded-full border border-line px-5 py-2 text-sm transition-colors hover:text-accent" data-lang-choice="en">English</a>
        <a href="/zh" class="rounded-full border border-line px-5 py-2 text-sm transition-colors hover:text-accent" data-lang-choice="zh">中文</a>
      </div>
    </div>

    <script is:inline>
      (() => {
        const storageKey = "atelier-ko-locale";
        const supported = ["en", "zh"];

        function savedLocale() {
          try {
            const value = window.localStorage.getItem(storageKey);
            if (supported.includes(value)) return value;
          } catch {}
          const match = document.cookie.match(/(?:^|; )atelier-ko-locale=(en|zh)(?:;|$)/);
          return match?.[1];
        }

        function browserLocale() {
          const languages = navigator.languages?.length ? navigator.languages : [navigator.language];
          return languages.some((language) => /^zh\b/i.test(language || "")) ? "zh" : "en";
        }

        const target = savedLocale() || browserLocale();
        window.location.replace(`/${target}`);
      })();
    </script>
  </main>
</BaseLayout>
