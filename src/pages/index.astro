---
import { Image } from "astro:assets";
import ProductCard from "@/components/ProductCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import heroImg from "@/assets/buweihao-hero.jpg";
import { getProducts } from "@/data/products.js";

const products = await getProducts();
const categories = [
  { name: "清洁", copy: "温和带走油脂、防晒与日常脏污，保留洗后舒适感。" },
  { name: "补水", copy: "用轻盈水感配方，为干燥和换季状态打好底。" },
  { name: "防晒", copy: "清爽成膜，适合通勤、出行和每天都要做的防护。" },
  { name: "抗衰", copy: "围绕屏障、干纹和弹润观感，建立夜间修护节奏。" },
];
---

<BaseLayout
  title="buweihao — 清洁、补水、防晒、抗衰护肤产品"
  description="buweihao 是一个个人护肤电商产品展示站，提供清洁、补水、防晒与抗衰四类日常护肤产品。"
  image={heroImg}
>
  <main id="main-content">
    <section class="relative overflow-hidden bg-base">
      <div class="md:hidden">
        <div class="aspect-[4/3] w-full">
          <Image
            src={heroImg}
            alt="buweihao 极简护肤产品组合"
            width={1600}
            height={1100}
            format="webp"
            loading="eager"
            decoding="sync"
            class="h-full w-full object-cover object-right"
          />
        </div>
        <div class="space-y-6 px-6 py-12">
          <p class="flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
            <span class="inline-block h-px w-8 bg-ink/40"></span>
            Clean care for everyday skin
          </p>
          <h1 class="text-balance font-serif text-4xl leading-[0.95]">
            buweihao
            <br />
            <span class="italic text-accent">把日常护肤做清楚。</span>
          </h1>
          <p class="max-w-[48ch] text-pretty leading-relaxed text-faded">
            从清洁、补水、防晒到抗衰，围绕每天都会用到的护肤步骤，提供轻盈、有效、好坚持的产品组合。
          </p>
          <div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center">
            <a
              href="/products"
              class="group inline-flex items-center gap-3 rounded-full bg-ink px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent"
            >
              查看产品
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
            </a>
            <a href="/about" class="text-[11px] uppercase tracking-[0.2em] text-faded transition-colors hover:text-ink">
              了解品牌 →
            </a>
          </div>
        </div>
      </div>

      <div class="relative hidden h-[88vh] max-h-[920px] min-h-[640px] w-full md:block">
        <Image
          src={heroImg}
          alt="buweihao 极简护肤产品组合"
          width={2048}
          height={1200}
          format="webp"
          loading="eager"
          decoding="sync"
          class="absolute inset-0 h-full w-full object-cover object-right"
        />
        <div
          aria-hidden="true"
          class="absolute inset-0"
          style="background: linear-gradient(90deg, var(--color-base) 0%, var(--color-base) 30%, color-mix(in oklab, var(--color-base) 62%, transparent) 48%, transparent 78%)"
        >
        </div>
        <div class="relative mx-auto flex h-full max-w-screen-xl items-center px-6">
          <div class="max-w-[500px] space-y-8">
            <p class="flex items-center gap-3 text-[11px] uppercase tracking-[0.3em] text-faded">
              <span class="inline-block h-px w-8 bg-ink/40"></span>
              Clean care for everyday skin
            </p>
            <h1 class="text-balance font-serif text-5xl leading-[0.95] lg:text-7xl">
              buweihao
              <br />
              <span class="italic text-accent">把日常护肤做清楚。</span>
            </h1>
            <p class="max-w-[48ch] text-pretty leading-relaxed text-faded md:text-lg">
              从清洁、补水、防晒到抗衰，围绕每天都会用到的护肤步骤，提供轻盈、有效、好坚持的产品组合。
            </p>
            <div class="flex items-center gap-6 pt-2">
              <a
                href="/products"
                class="group inline-flex items-center gap-3 rounded-full bg-ink px-7 py-4 text-[11px] font-medium uppercase tracking-[0.2em] text-[var(--color-base)] transition-colors hover:bg-accent"
              >
                查看产品
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
              </a>
              <a href="/contact" class="text-[11px] uppercase tracking-[0.2em] text-faded transition-colors hover:text-ink">
                联系我们 →
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-screen-xl px-6 pt-24 md:pt-32">
      <div class="mb-12 flex items-end justify-between gap-6 border-t border-line pt-10">
        <div>
          <p class="mb-4 text-[11px] uppercase tracking-[0.3em] text-faded">Product system</p>
          <h2 class="max-w-[18ch] text-balance font-serif text-3xl md:text-5xl">
            四个步骤，<span class="italic text-accent">覆盖日常护理。</span>
          </h2>
        </div>
        <a
          href="/products"
          class="hidden items-center gap-2 whitespace-nowrap text-[11px] uppercase tracking-[0.2em] text-faded transition-colors hover:text-ink md:inline-flex"
        >
          全部产品
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <div class="grid gap-x-8 gap-y-10 md:grid-cols-4">
        {
          categories.map((item) => (
            <a href={`/products?category=${encodeURIComponent(item.name)}`} class="space-y-3 border-t border-line pt-5 transition-colors hover:text-accent">
              <p class="text-[10px] uppercase tracking-[0.3em] text-faded">{item.name}</p>
              <h3 class="font-serif text-2xl">{item.name}护理</h3>
              <p class="text-sm leading-relaxed text-faded">{item.copy}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="mx-auto mt-32 max-w-screen-xl px-6 md:mt-40">
      <div class="mb-12 flex items-end justify-between gap-6 border-t border-line pt-10">
        <div>
          <p class="mb-4 text-[11px] uppercase tracking-[0.3em] text-faded">Featured products</p>
          <h2 class="max-w-[20ch] text-balance font-serif text-3xl md:text-5xl">
            适合上架展示的<span class="italic text-accent">核心产品。</span>
          </h2>
        </div>
      </div>

      <div class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-4">
        {products.map((product, index) => <ProductCard product={product} eager={index < 2} />)}
      </div>
    </section>

    <section class="mx-auto my-32 max-w-screen-xl px-6 md:my-40">
      <div class="grid items-end gap-10 border-y border-line py-12 md:grid-cols-12">
        <div class="md:col-span-7">
          <p class="mb-5 text-[11px] uppercase tracking-[0.3em] text-faded">Sanity ready</p>
          <h2 class="max-w-[18ch] text-balance font-serif text-3xl md:text-5xl">
            内容可迁移到 Sanity，<span class="italic text-accent">前台保持静态快速。</span>
          </h2>
        </div>
        <div class="space-y-5 text-sm leading-relaxed text-faded md:col-span-5">
          <p>
            当前产品以 Astro 内容集合驱动，已补充 Sanity Studio 配置和产品 schema，后续可以接入 Sanity dataset 管理产品、分类与图片。
          </p>
          <a href="/contact" class="inline-flex text-[11px] uppercase tracking-[0.2em] text-ink transition-colors hover:text-accent">
            合作咨询 →
          </a>
        </div>
      </div>
    </section>

    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      name: "buweihao",
      url: Astro.site?.href ?? "https://atelier-ko.weihaobu.cn/",
      email: "buweihao@qq.com",
      sameAs: ["https://baidu.com"],
    })}></script>
  </main>
</BaseLayout>
