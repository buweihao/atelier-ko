---
import { defaultLocale, localePath, ui } from "@/lib/i18n";

const year = new Date().getFullYear();
const { lang = defaultLocale } = Astro.props;
const copy = ui[lang];
---

<footer id="studio" class="mt-32 border-t border-line py-24">
  <div class="mx-auto grid max-w-screen-xl grid-cols-1 gap-12 px-6 md:grid-cols-3">
    <div class="space-y-4">
      <div class="font-serif text-lg italic tracking-tight">buweihao</div>
      <p class="max-w-[30ch] text-sm leading-relaxed text-faded">
        {copy.footerCopy}
      </p>
    </div>
    <div class="space-y-4">
      <h2 class="text-xs font-medium uppercase tracking-widest">{copy.footerNav}</h2>
      <ul class="space-y-2 text-sm">
        {
          copy.nav.slice(1).map((item) => (
            <li>
              <a href={localePath(lang, item.href)} class="text-faded transition-colors hover:text-ink">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div class="space-y-4">
      <h2 class="text-xs font-medium uppercase tracking-widest">{copy.footerContact}</h2>
      <ul class="space-y-2 text-sm">
        <li><a href="mailto:buweihao@qq.com" class="text-faded transition-colors hover:text-ink">buweihao@qq.com</a></li>
        <li><a href="https://baidu.com" class="text-faded transition-colors hover:text-ink">baidu.com</a></li>
      </ul>
    </div>
  </div>
  <div class="mx-auto mt-16 max-w-screen-xl px-6 text-[10px] uppercase tracking-[0.2em] text-faded">
    © {year} buweihao — Daily skincare essentials.
  </div>
</footer>
