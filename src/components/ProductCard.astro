---
import { Image } from "astro:assets";
import { formatPrice } from "@/data/products.js";
import { defaultLocale, localePath } from "@/lib/i18n";

const { product, eager = false, lang = defaultLocale } = Astro.props;
const image = product.images[0];
const imageAlt = `${product.name} — ${product.shortDescription}`;
---

<a href={localePath(lang, `/products/${product.slug}`)} class="group block space-y-4" data-product-card>
  <div class="aspect-[4/5] overflow-hidden rounded-[min(1vw,12px)] bg-paper">
    {
      typeof image === "string" ? (
        <img
          src={image}
          alt={imageAlt}
          width="1024"
          height="1280"
          loading={eager ? "eager" : "lazy"}
          decoding={eager ? "sync" : "async"}
          class="h-full w-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.03]"
        />
      ) : (
        <Image
          src={image}
          alt={imageAlt}
          width={1024}
          height={1280}
          loading={eager ? "eager" : "lazy"}
          decoding={eager ? "sync" : "async"}
          format="webp"
          class="h-full w-full object-cover transition-transform duration-[1200ms] ease-out group-hover:scale-[1.03]"
        />
      )
    }
  </div>
  <div class="flex items-start justify-between gap-4">
    <div>
      <h2 class="text-sm font-medium">{product.name}</h2>
      <p class="text-xs text-faded">{product.shortDescription}</p>
    </div>
    <span class="text-sm tabular-nums">{formatPrice(product.price, lang)}</span>
  </div>
</a>
