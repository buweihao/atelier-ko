---
import { Image } from "astro:assets";
import { formatPrice, getProducts } from "@/data/products.js";
import { defaultLocale, localeLabels, localePath, locales, stripLocale, ui } from "@/lib/i18n";

const { currentPath = "/", lang = defaultLocale } = Astro.props;
const copy = ui[lang];
const untranslatedPath = stripLocale(currentPath);

const isActive = (href = "") => {
  if (href === "/") return untranslatedPath === "/";
  return untranslatedPath.startsWith(href);
};

const navItems = copy.nav.map((item) => ({
  ...item,
  href: localePath(lang, item.href),
  baseHref: item.href,
}));

const products = await getProducts(lang);
const featuredProduct = products.find((product) => product.slug === "hydration-serum") ?? products[0];

if (!featuredProduct) {
  throw new Error("Missing products for mobile menu");
}

const featuredImage = featuredProduct.images[0];
const featuredAlt = `${featuredProduct.name} - ${featuredProduct.shortDescription}`;
const openMenuLabel = lang === "zh" ? "打开菜单" : "Open menu";
const closeMenuLabel = lang === "zh" ? "关闭菜单" : "Close menu";
---

<nav class="sticky top-0 z-50 border-b border-line bg-base/80 backdrop-blur-md" aria-label="Main navigation">
  <div class="mx-auto flex h-16 max-w-screen-xl items-center justify-between px-6">
    <a href={localePath(lang, "/")} class="font-serif text-xl italic tracking-tight" aria-label="buweihao">
      buweihao
    </a>
    <div class="hidden items-center gap-8 text-sm md:flex">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              "transition-colors hover:text-accent",
              isActive(item.baseHref) ? "text-ink" : "text-faded",
            ]}
            aria-current={isActive(item.baseHref) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </div>
    <div class="flex items-center gap-3">
      <div class="hidden items-center rounded-full border border-line p-0.5 text-[11px] font-medium md:flex" aria-label="Language">
        {
          locales.map((locale) => (
            <a
              href={localePath(locale, untranslatedPath)}
              class:list={[
                "rounded-full px-2.5 py-1 transition-colors hover:text-accent",
                locale === lang ? "bg-ink text-[var(--color-base)]" : "text-faded",
              ]}
              aria-current={locale === lang ? "page" : undefined}
              data-lang-choice={locale}
            >
              {localeLabels[locale]}
            </a>
          ))
        }
      </div>
      <a
        href={localePath(lang, "/cart")}
        data-cart-label
        aria-label={copy.cartAria(0)}
        class="relative inline-flex items-center gap-1.5 p-1 text-sm font-medium transition-colors hover:text-accent"
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M6 8h12l-1 12H7L6 8Z"></path>
          <path d="M9 8a3 3 0 0 1 6 0"></path>
        </svg>
        <span class="tabular-nums text-faded" data-cart-count>(0)</span>
      </a>
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full text-ink transition-colors hover:text-accent md:hidden"
        aria-label={openMenuLabel}
        aria-controls="mobile-menu"
        aria-expanded="false"
        data-mobile-menu-open
      >
        <span class="sr-only">{openMenuLabel}</span>
        <span class="flex w-4 flex-col gap-1.5" aria-hidden="true">
          <span class="h-px w-full bg-current"></span>
          <span class="h-px w-full bg-current"></span>
          <span class="h-px w-full bg-current"></span>
        </span>
      </button>
    </div>
  </div>
</nav>

<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] hidden h-dvh overflow-hidden bg-base text-ink md:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile menu"
  data-mobile-menu
>
  <div class="flex h-full flex-col px-6 pb-6 pt-5">
    <div class="flex h-11 items-center justify-between">
      <a href={localePath(lang, "/")} class="font-serif text-xl italic tracking-tight" aria-label="buweihao" data-mobile-menu-link>
        buweihao
      </a>
      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full text-ink transition-colors hover:text-accent"
        aria-label={closeMenuLabel}
        data-mobile-menu-close
      >
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M6 6l12 12"></path>
          <path d="M18 6L6 18"></path>
        </svg>
      </button>
    </div>

    <div class="flex min-h-0 flex-1 flex-col gap-5 pt-7">
      <div class="space-y-2.5">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "block font-serif text-4xl leading-none transition-colors hover:text-accent",
                isActive(item.baseHref) ? "text-ink" : "text-faded",
              ]}
              aria-current={isActive(item.baseHref) ? "page" : undefined}
              data-mobile-menu-link
            >
              {item.label}
            </a>
          ))
        }
        <a
          href={localePath(lang, "/cart")}
          data-cart-label
          aria-label={copy.cartAria(0)}
          class="inline-flex items-center gap-2 pt-1 text-sm uppercase tracking-[0.2em] text-faded transition-colors hover:text-ink"
          data-mobile-menu-link
        >
          {copy.cart}
          <span class="tabular-nums" data-cart-count>(0)</span>
        </a>
        <div class="flex flex-wrap gap-2 pt-2">
          {
            locales.map((locale) => (
              <a
                href={localePath(locale, untranslatedPath)}
                class:list={[
                  "rounded-full border border-line px-3 py-1.5 text-xs transition-colors hover:text-accent",
                  locale === lang ? "bg-ink text-[var(--color-base)]" : "text-faded",
                ]}
                data-mobile-menu-link
                data-lang-choice={locale}
              >
                {localeLabels[locale]}
              </a>
            ))
          }
        </div>
      </div>

      <a
        href={localePath(lang, `/products/${featuredProduct.slug}`)}
        class="group block border-y border-line py-4"
        data-mobile-menu-link
      >
        <div class="aspect-[16/10] max-h-[32dvh] overflow-hidden rounded-md bg-paper">
          {
            typeof featuredImage === "string" ? (
              <img
                src={featuredImage}
                alt={featuredAlt}
                width="900"
                height="560"
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
              />
            ) : (
              <Image
                src={featuredImage}
                alt={featuredAlt}
                width={900}
                height={560}
                format="webp"
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
              />
            )
          }
        </div>
        <div class="mt-3 flex items-end justify-between gap-4">
          <div class="min-w-0 space-y-1.5">
            <p class="text-[10px] uppercase tracking-[0.3em] text-faded">{copy.featuredProduct}</p>
            <p class="font-serif text-3xl leading-none">{featuredProduct.name}</p>
            <p class="text-sm leading-relaxed text-faded">{featuredProduct.shortDescription}</p>
          </div>
          <p class="shrink-0 pb-0.5 text-xs uppercase tracking-[0.2em] text-accent">
            {formatPrice(featuredProduct.price, lang)}
          </p>
        </div>
      </a>

      <div class="mt-auto space-y-2 text-sm">
        <p class="text-[10px] uppercase tracking-[0.3em] text-faded">{copy.contact}</p>
        <a href="mailto:buweihao@qq.com" class="block transition-colors hover:text-accent" data-mobile-menu-link>
          buweihao@qq.com
        </a>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const menu = document.querySelector("[data-mobile-menu]");
    const openButton = document.querySelector("[data-mobile-menu-open]");
    const closeButton = document.querySelector("[data-mobile-menu-close]");

    document.querySelectorAll("[data-lang-choice]").forEach((link) => {
      link.addEventListener("click", () => {
        try {
          window.localStorage.setItem("atelier-ko-locale", link.dataset.langChoice);
          document.cookie = `atelier-ko-locale=${link.dataset.langChoice}; path=/; max-age=31536000; SameSite=Lax`;
        } catch {}
      });
    });

    if (!menu || !openButton || !closeButton) return;

    const focusableSelector = [
      "a[href]",
      "button:not([disabled])",
      "input:not([disabled])",
      "select:not([disabled])",
      "textarea:not([disabled])",
      '[tabindex]:not([tabindex="-1"])',
    ].join(",");
    let lastFocusedElement;

    function getFocusable() {
      return Array.from(menu.querySelectorAll(focusableSelector)).filter((element) => {
        return element instanceof HTMLElement && element.offsetParent !== null;
      });
    }

    function lockScroll() {
      document.documentElement.style.overflow = "hidden";
      document.body.style.overflow = "hidden";
    }

    function unlockScroll() {
      document.documentElement.style.overflow = "";
      document.body.style.overflow = "";
    }

    function openMenu() {
      lastFocusedElement = document.activeElement;
      menu.classList.remove("hidden");
      openButton.setAttribute("aria-expanded", "true");
      lockScroll();
      closeButton.focus({ preventScroll: true });
    }

    function closeMenu({ restoreFocus = true } = {}) {
      menu.classList.add("hidden");
      openButton.setAttribute("aria-expanded", "false");
      unlockScroll();

      if (restoreFocus && lastFocusedElement instanceof HTMLElement) {
        lastFocusedElement.focus({ preventScroll: true });
      }
    }

    openButton.addEventListener("click", openMenu);
    closeButton.addEventListener("click", () => closeMenu());

    menu.querySelectorAll("[data-mobile-menu-link]").forEach((link) => {
      link.addEventListener("click", () => closeMenu({ restoreFocus: false }));
    });

    document.addEventListener("keydown", (event) => {
      if (menu.classList.contains("hidden")) return;

      if (event.key === "Escape") {
        event.preventDefault();
        closeMenu();
        return;
      }

      if (event.key !== "Tab") return;

      const focusable = getFocusable();
      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (!first || !last) return;

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });

    window.addEventListener("resize", () => {
      if (window.matchMedia("(min-width: 768px)").matches && !menu.classList.contains("hidden")) {
        closeMenu({ restoreFocus: false });
      }
    });
  })();
</script>
